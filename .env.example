# NanoHarness provider template
# Enable exactly one provider block below.
#
# Supported API format families in the current runtime:
# 1. Anthropic-compatible
# 2. OpenAI Responses / OpenAI official
# 3. OpenAI-compatible
#
# Runtime note:
# - `MODEL_PROVIDER` selects the SDK family used inside Deep Agents.
# - `MODEL_API_FORMAT` makes the chosen wire format explicit for users/operators.

ASSISTANT_NAME=Andy
CONTAINER_IMAGE=nanoharness-agent:latest

# Optional long-run reliability tuning
# NANOCLAW_AGENT_MAX_RETRIES=2
# NANOCLAW_AGENT_RETRY_BASE_MS=5000
# NANOCLAW_TASK_MAX_RETRIES=3
# NANOCLAW_TASK_RETRY_BASE_MS=10000
# NANOCLAW_AUTO_CONTINUE_LIMIT=6
# NANOCLAW_AUTO_CONTINUE_SCHEDULED=0

################################################################################
# Option 1: Anthropic-compatible API
################################################################################
# MODEL_PROVIDER=anthropic
# MODEL_API_FORMAT=anthropic
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_MODEL=claude-sonnet-4-5
#
# Optional Anthropic alias pinning
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5

################################################################################
# Option 2: OpenAI Responses / official OpenAI endpoint
################################################################################
# MODEL_PROVIDER=openai
# MODEL_API_FORMAT=openai-responses
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-openai-your-key
# OPENAI_MODEL=gpt-4.1

################################################################################
# Option 3: OpenAI-compatible endpoint
################################################################################
# MODEL_PROVIDER=openai
# MODEL_API_FORMAT=openai-compatible
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
# OPENAI_API_KEY=sk-your-compatible-key
# OPENAI_MODEL=gpt-4.1

# Optional: shared override for subagents
# CLAUDE_CODE_SUBAGENT_MODEL=gpt-4.1-mini
