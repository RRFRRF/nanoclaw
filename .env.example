# NanoHarness provider template
# Enable exactly one provider block below.
#
# Supported API format families in the current runtime:
# 1. Anthropic-compatible
# 2. OpenAI Responses / OpenAI official
# 3. OpenAI-compatible
#
# Runtime note:
# - `MODEL_PROVIDER` selects the SDK family used inside Deep Agents.
# - `MODEL_API_FORMAT` makes the chosen wire format explicit for users/operators.

ASSISTANT_NAME=Andy
CONTAINER_IMAGE=nanoharness-agent:latest

# Optional long-run reliability tuning
# NANOCLAW_AGENT_MAX_RETRIES=2
# NANOCLAW_AGENT_RETRY_BASE_MS=5000
# NANOCLAW_TASK_MAX_RETRIES=3
# NANOCLAW_TASK_RETRY_BASE_MS=10000
# NANOCLAW_AUTO_CONTINUE_LIMIT=6
# NANOCLAW_AUTO_CONTINUE_SCHEDULED=0

################################################################################
# Streaming Output Configuration
# Controls real-time streaming display of agent execution
################################################################################
# Enable/disable streaming output (default: true)
# NANOCLAW_STREAMING=true

# Show thinking process (default: true)
# NANOCLAW_SHOW_THINKING=true

# Show execution plan (default: true)
# NANOCLAW_SHOW_PLAN=true

# Show tool calls (default: true)
# NANOCLAW_SHOW_TOOLS=true

# Stream buffer size in bytes (default: 1000)
# NANOCLAW_STREAM_BUFFER_SIZE=1000

# Maximum events to keep in memory (default: 10000)
# NANOCLAW_STREAM_MAX_EVENTS=10000

################################################################################
# Option 1: Anthropic-compatible API
################################################################################
# MODEL_PROVIDER=anthropic
# MODEL_API_FORMAT=anthropic
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_MODEL=claude-sonnet-4-5
#
# Optional Anthropic alias pinning
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5

################################################################################
# Option 2: OpenAI Responses / official OpenAI endpoint
################################################################################
# MODEL_PROVIDER=openai
# MODEL_API_FORMAT=openai-responses
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-openai-your-key
# OPENAI_MODEL=gpt-4.1

################################################################################
# Option 3: OpenAI-compatible endpoint
################################################################################
# MODEL_PROVIDER=openai
# MODEL_API_FORMAT=openai-compatible
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
# OPENAI_API_KEY=sk-your-compatible-key
# OPENAI_MODEL=gpt-4.1

# Optional: shared override for subagents
# CLAUDE_CODE_SUBAGENT_MODEL=gpt-4.1-mini
# NANOCLAW_ENABLE_PREDEFINED_SUBAGENTS=true
# Optional role-specific skill roots (comma-separated)
# NANOCLAW_SUBAGENT_RESEARCHER_SKILLS=/workspace/group/.deepagents-skills/research
# NANOCLAW_SUBAGENT_CODER_SKILLS=/workspace/group/.deepagents-skills/coder
# NANOCLAW_SUBAGENT_REVIEWER_SKILLS=/workspace/group/.deepagents-skills/reviewer
# Optional: native human-in-the-loop approval policy for specific tools
# Example: {"write_file":true,"edit_file":{"allowedDecisions":["approve","reject"]},"mcp__nanoclaw__send_message":{"allowedDecisions":["approve","reject"]}}
# NANOCLAW_INTERRUPT_ON_JSON=

# Optional: experimental native streaming bridge
# NANOCLAW_USE_NATIVE_STREAMING=false
# NANOCLAW_STREAM_CONTENT_FROM_NATIVE=false
# Optional: write sanitized native stream debug shapes to .nanoclaw/runtime-context/native-stream-debug.jsonl
# Disabled by default to avoid leaking prompt/tool payloads into debug logs.
# NANOCLAW_DEBUG_NATIVE_STREAM=false
# Optional: disable invoke() fallback when the native stream path fails locally
# NANOCLAW_DISABLE_NATIVE_STREAM_FALLBACK=false
